# Database Configuration
DB_HOST=your-database-host
DB_PORT=5432
DB_USERNAME=your-database-username
DB_PASSWORD=your-database-password
DB_DATABASE=your-database-name
DB_SSL=true
DB_LOGGING=false

# Example for DigitalOcean PostgreSQL
# DB_HOST=db-postgresql-blr1-xxxxx-do-user-xxxxx-0.f.db.ondigitalocean.com
# DB_PORT=25060
# DB_USERNAME=doadmin
# DB_PASSWORD=your-actual-password
# DB_DATABASE=defaultdb
# DB_SSL=true
# DB_LOGGING=true

# Redis / Bull queue (required for the reminder + scheduler execution engine)
BULL_REDIS_HOST=localhost
BULL_REDIS_PORT=6379

# SMTP / Email delivery (consumed by notifications EmailService — reminders,
# scheduled reports, automation-rule notifications). Leave unset to disable sends.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM="ERP System <noreply@erp.com>"
FRONTEND_URL=http://localhost:3000

# Object storage (attachments + HR documents). S3-compatible: AWS S3,
# Cloudflare R2, or self-hosted MinIO. If S3_BUCKET/S3_ACCESS_KEY_ID/
# S3_SECRET_ACCESS_KEY are all set, uploads go to S3 (with automatic local-disk
# fallback if S3 is unreachable). If unset, files are stored on local disk (uploads/).
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com   # set for R2 / MinIO (enables path-style)
