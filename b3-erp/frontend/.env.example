# Domain (NestJS) backend base URL — MUST include the /api/v1 global prefix.
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Platform (Django) backend base URL (tenancy/identity/audit).
NEXT_PUBLIC_PLATFORM_API_URL=http://localhost:8000/api/v1

# Real-time / websocket origin (no path prefix).
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Set 'true' only to force in-memory mock data instead of the live API.
NEXT_PUBLIC_USE_MOCK_DATA=false

# Feature flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
