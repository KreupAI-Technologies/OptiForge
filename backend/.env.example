# Django (OptiForge PLATFORM) backend — local dev database config.
#
# Copy to backend/.env and fill in real values:
#     cp backend/.env.example backend/.env
#
# Per ADR-0004 the two backends share ONE Postgres cluster. Use the same
# credentials the NestJS domain backend uses (see b3-erp/backend/.env).
# For the shared Neon cluster, DATABASE_SSLMODE must be `require`.
#
# settings.py loads this file via python-dotenv at startup. Without it,
# Django falls back to test/test/test_db@localhost and fails to connect.

DATABASE_NAME=neondb
DATABASE_USER=neondb_owner
DATABASE_PASSWORD=change-me
DATABASE_HOST=your-neon-host.aws.neon.tech
DATABASE_PORT=5432
DATABASE_SSLMODE=require
